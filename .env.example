# Copie para `.env` na raiz do projeto e preencha com credenciais de teste.
# (Opcional: `tests/.env` sobrescreve valores da raiz.)

# Ambiente: `local` (localhost:4200) ou `app` (produção).
# Também pode usar os scripts: npm run test:local | npm run test:app
E2E_TARGET=app

# Opcional — sobrescreve o preset do E2E_TARGET:
# E2E_BASE_URL=http://localhost:4200
# E2E_API_URL=http://localhost:3000/api
# E2E_BASE_URL=https://app.controledental.com.br
# E2E_API_URL=https://api.controledental.com.br/api

E2E_USER_EMAIL=seu-email@exemplo.com
E2E_USER_PASSWORD="sua-senha-com-caracteres-especiais"

# Billing/checkout: mantenha false (default) para mockar APIs de cobrança nos testes.
# Defina true apenas se souber que está em ambiente sandbox e quer testar integração real.
E2E_ALLOW_REAL_BILLING=false
